{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "noEmit": true
  },
  "include": ["packages/shared/src/**/*.ts", "packages/core/src/**/*.ts", "apps/desktop/src/renderer/**/*.tsx", "apps/desktop/src/renderer/**/*.d.ts", "apps/web/src/**/*.tsx", "apps/web/src/**/*.ts", "vite.*.config.ts"]
}
